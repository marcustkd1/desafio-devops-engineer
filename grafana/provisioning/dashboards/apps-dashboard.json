{
  "title": "Aplicações - FastAPI & Go",
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Volume de Requisições (Python FastAPI)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (handler) (increase(http_requests_total{job=\"python-app\"}[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Volume de Requisições (Go App)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (handler) (increase(go_http_requests_total{job=\"go-app\"}[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latência Média (Python FastAPI)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_request_duration_seconds_sum{job=\"python-app\"}[5m])) / sum by (handler) (rate(http_request_duration_seconds_count{job=\"python-app\"}[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latência Média (Go App)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (handler) (rate(go_http_request_duration_seconds_sum{job=\"go-app\"}[5m])) / sum by (handler) (rate(go_http_request_duration_seconds_count{job=\"go-app\"}[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Status Codes (Python FastAPI)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (status) (increase(http_requests_total{job=\"python-app\"}[5m]))",
          "legendFormat": "HTTP {{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Status Codes (Go App)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (status) (increase(go_http_requests_total{job=\"go-app\"}[5m]))",
          "legendFormat": "HTTP {{status}}"
        }
      ]
    }
  ]
}
